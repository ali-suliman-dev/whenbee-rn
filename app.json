{
  "expo": {
    "name": "Whenbee",
    "slug": "whenbee",
    "owner": "alx-organization",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "whenbee",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.whenbee.app",
      "supportsTablet": true,
      "appleTeamId": "KXJDWZ2PKA",
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.usernotifications.time-sensitive": true
      }
    },
    "android": {
      "package": "com.whenbee.app",
      "adaptiveIcon": {
        "backgroundColor": "#41378B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 3,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.POST_PROMOTED_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 190,
          "resizeMode": "contain",
          "backgroundColor": "#41378B",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 190,
            "resizeMode": "contain",
            "backgroundColor": "#2B2460"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-calendar",
        {
          "calendarPermission": "Whenbee reads today's events so it can show your honest day, and only writes back the times you confirm."
        }
      ],
      "./plugins/withNoRemindersPermission",
      "./plugins/withNoExternalStoragePermission",
      "expo-localization",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Whenbee uses the mic so you can speak a task instead of typing.",
          "speechRecognitionPermission": "Speech is transcribed on your device — it never leaves your phone."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          },
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "4be512ee-fdc9-429e-8e14-d27d7b187be6"
      }
    }
  }
}
