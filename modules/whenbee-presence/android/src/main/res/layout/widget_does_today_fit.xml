<?xml version="1.0" encoding="utf-8"?>
<!-- "Does Today Fit?" Home-screen widget (Pro). Presentation-only: renders the
     CapacityWidgetData snapshot JS wrote (useCapacityWidgetPublisher.ts -> key "capacity").
     Colors mirror src/theme/tokens.ts (dark surface). RemoteViews-safe views only. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dtf_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- Spacer above the verdict block so it sits optically centred in the tile. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Verdict main line ("Your day fits" / "Runs ~25m long" / "Does today fit?") -->
    <TextView
        android:id="@+id/dtf_verdict"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="@string/does_today_fit_locked"
        android:textColor="#F4F1EA"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Caption ("~40 min slack" / "Pro"). Accent; hidden for none. -->
    <TextView
        android:id="@+id/dtf_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="@string/does_today_fit_pro"
        android:textColor="#EEAE4D"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Capacity bar — a horizontal ProgressBar; fill set via setProgressBar().
         Hidden entirely for the locked/free state (no marker leaks). Concrete framework
         horizontal style so it resolves without depending on the launcher host theme;
         visuals come from our own progressDrawable. -->
    <ProgressBar
        android:id="@+id/dtf_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="12dp"
        android:max="1000"
        android:progress="0"
        android:indeterminate="false"
        android:progressDrawable="@drawable/widget_bar"
        android:visibility="gone" />

    <!-- Bottom spacer balances the top spacer to keep the block centred. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
