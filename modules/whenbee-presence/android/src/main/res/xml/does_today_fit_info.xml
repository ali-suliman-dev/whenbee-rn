<?xml version="1.0" encoding="utf-8"?>
<!-- "Does Today Fit?" widget — small (2x1 default placement), matches the other two. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="40dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewImage="@drawable/doestodayfit_preview"
    android:initialLayout="@layout/widget_does_today_fit"
    android:updatePeriodMillis="1800000"
    android:description="@string/does_today_fit_description" />
