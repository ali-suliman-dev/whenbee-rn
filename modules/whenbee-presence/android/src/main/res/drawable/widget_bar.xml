<?xml version="1.0" encoding="utf-8"?>
<!-- Pro fill bar: surfaceSunken track + amber accent progress. Driven by
     RemoteViews.setProgressBar(fraction) — the standard, API-24-safe way to show a
     proportional fill in a widget (RemoteViews has no layout-weight setter). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="#15161F" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="#EEAE4D" />
                <corners android:radius="3dp" />
            </shape>
        </clip>
    </item>
</layer-list>
